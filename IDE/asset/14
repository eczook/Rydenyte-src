				<string name="Source">ball = script.Parent
damage = 55

r = game:service(&quot;RunService&quot;)

last_sound_time = r.Stepped:wait()

function findHumanoid(p)
	if (p.className == Workspace) then return nil end
	local h = p:FindFirstChild(&quot;Humanoid&quot;)
	if (h ~= nil) then return h end
	if (p.Parent ~= nil) then return findHumanoid(p.Parent) end
	return nil
end

function onTouched(hit)

	local now = r.Stepped:wait()

	if (now - last_sound_time &gt; .1) then
		ball.Boing:play()
		last_sound_time = now
	else
		return
	end

	local humanoid = findHumanoid(hit)
	if humanoid~=nil then
		tagHumanoid(humanoid)
		humanoid:TakeDamage(damage)
		wait(2)
		untagHumanoid(humanoid)
		connection:disconnect()
	else
		damage = damage / 2
		if damage &lt; 2 then
			connection:disconnect()
		end
	end
end

function tagHumanoid(humanoid)
	-- todo: make tag expire
	local tag = ball:findFirstChild(&quot;creator&quot;)
	if tag ~= nil then
		local new_tag = tag:clone()
		new_tag.Parent = humanoid
	end
end


function untagHumanoid(humanoid)
	if humanoid ~= nil then
		local tag = humanoid:findFirstChild(&quot;creator&quot;)
		if tag ~= nil then
			tag.Parent = nil
		end
	end
end

connection = ball.Touched:connect(onTouched)


t, s = r.Stepped:wait()
d = t + 5.0 - s
while t &lt; d do
	t = r.Stepped:wait()
end

